# Database
# DB connection - not yet used in MVP, using in-memory store
# Backend services currently use ConcurrentHashMap-based in-memory repositories.
# These settings are consumed by docker-compose.yml for PostgreSQL container only.
# Phase 2 will connect the application to PostgreSQL.
MOTTAINAI_DB_NAME=mottainai
MOTTAINAI_DB_USER=mottainai
MOTTAINAI_DB_PASSWORD=mottainai_dev
MOTTAINAI_DB_PORT=5432

# Backend (Kotlin/Quarkus)
# MOTTAINAI_DB_URL is prepared for Phase 2 PostgreSQL migration
MOTTAINAI_DB_URL=postgresql://localhost:5432/mottainai
QUARKUS_GRPC_SERVER_PORT=9090

# Routing (Go)
ROUTING_GRPC_PORT=9091
